# Puerto del servidor
PORT=3000

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# Ruta al archivo de credenciales de Firebase Admin SDK
# Descarga este archivo desde Firebase Console > Project Settings > Service Accounts
FIREBASE_ADMIN_SDK_PATH=./server/config/firebase-adminsdk.json

# Firebase Cloud Messaging Configuration
# Obtén estos valores desde Firebase Console > Project Settings > Cloud Messaging
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_PRIVATE_KEY_ID=tu-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_PRIVATE_KEY_AQUI\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto-firebase.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=tu-client-id

# Configuración de la base de datos
DB_PATH=./server/data/notifications.db

# Configuración de seguridad
# Genera una clave secreta segura (puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SECRET_KEY=tu-clave-secreta-aqui

# Rate limiting (peticiones por minuto)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Entorno de ejecución
NODE_ENV=development
